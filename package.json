{
  "name": "@macrostrat/rockd-website",
  "private": true,
  "version": "2.4.0",
  "description": "Macrostrat map interface",
  "type": "module",
  "scripts": {
    "dev": "vike dev",
    "build": "vike build",
    "preview": "vike build && vike preview",
    "clean": "rm -rf dist/*",
    "server": "tsx __archive/index.old.ts",
    "server:dev": "tsx --env-file=.env __archive/index.old.ts",
    "format": "prettier --write src packages",
    "server:prod": "NODE_NO_WARNINGS=1 NODE_ENV=production yarn run __archive",
    "start": "yarn run build && yarn run __archive",
    "test:runtime": "tsx tests/test-urls.ts",
    "test": "vitest"
  },
  "authors": [
    "David Sklar <dsklar@wisc.edu>",
    "Daven Quinn <dev@davenquinn.com>"
  ],
  "license": "MIT",
  "devDependencies": {
    "@macrostrat/revision-info-webpack": "^1.0.0",
    "@mdx-js/rollup": "^2.3.0",
    "@types/esprima": "^4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/underscore": "^1",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^2.7.1",
    "sass": "^1.49.0",
    "stylus": "^0.55.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-cjs-interop": "^2.4.4",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.10.0",
    "@blueprintjs/select": "^6.1.4",
    "@blueprintjs/table": "^6.0.19",
    "@loadable/component": "^5.14.1",
    "@macrostrat/color-utils": "^1.2.1",
    "@macrostrat/data-components": "^1.1.3",
    "@macrostrat/form-components": "^1.0.4",
    "@macrostrat/hyper": "^3.0.6",
    "@macrostrat/map-interface": "^2.2.0",
    "@macrostrat/map-styles": "^2.1.0",
    "@macrostrat/mapbox-react": "^3.1.0",
    "@macrostrat/mapbox-utils": "^1.7.2",
    "@macrostrat/style-system": "^0.3.1",
    "@macrostrat/ui-components": "^5.0.5",
    "@macrostrat/vite-plugin-hyperstyles": "^2.0.0",
    "@supabase/postgrest-js": "^1.11.0",
    "@vitejs/plugin-react": "^4.0.4",
    "classnames": "^2.2.6",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "hex-to-css-filter": "^5.4.0",
    "jotai": "^2.18.1",
    "mapbox-gl": "^3.20.0",
    "react": "^19.2.4",
    "react-datepicker": "^7.5.0",
    "react-dom": "^19.2.4",
    "recharts": "^2.13.0",
    "transition-hook": "^1.5.2",
    "tsx": "^4.11.2",
    "vike": "^0.4.255",
    "vike-react": "^0.6.21",
    "zustand": "^4.5.1"
  },
  "prettier": {
    "proseWrap": "always"
  },
  "packageManager": "yarn@4.13.0"
}
