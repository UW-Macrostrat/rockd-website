{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": "./",
    // Allow importing of JSON and default imports from CommonJS modules
    "types": [
      "@macrostrat/vite-plugin-hyperstyles/client",
      "vite/client",
      "vike-react"
    ],
    "paths": {
      "~/*": ["src/*"],
      "#/*": ["pages/*"]
    }
  },
  "exclude": ["dist"]
}
